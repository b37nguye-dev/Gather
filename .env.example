# Database (Supabase PostgreSQL)
# Transaction pooler (port 6543) for app queries:
DATABASE_URL="postgresql://user:password@host:6543/database"
# Session pooler (port 5432) for Prisma migrations (supports advisory locks):
DIRECT_URL="postgresql://user:password@host:5432/database"

# JWT (access tokens only — refresh tokens are opaque UUIDs stored in DB)
ACCESS_TOKEN_SECRET="your-access-secret-min-32-chars"

# OAuth token encryption (32 bytes, hex or base64). Used for CalendarConnection in Phase 2.
OAUTH_ENCRYPTION_KEY="your-32-byte-hex-or-base64-key"

# API
PORT=3001

# CORS origin (frontend URL). Required for cross-domain cookies (Vercel + Railway).
CORS_ORIGIN="https://your-app.vercel.app"

# Node environment (production enables Secure + SameSite=None for refresh cookie)
NODE_ENV=development
